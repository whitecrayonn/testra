# Testra local development environment
# Copy to .env and adjust as needed. Never commit real secrets.

ENV=development
PORT=8080

# PostgreSQL (local native service — see ADR-009)
DATABASE_URL=postgres://testra:testra@localhost:5432/testra?sslmode=disable
MIGRATIONS_PATH=apps/api/migrations

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY_MINUTES=15
REFRESH_EXPIRY_DAYS=30
REFRESH_ABSOLUTE_DAYS=90

# Redis
REDIS_ADDR=localhost:6379

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123

# Object storage (MinIO local)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=testra
S3_SECRET_KEY=testratestra
S3_BUCKET=testra-dev

# SMTP (Mailpit local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@testra.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Stripe (optional; leave blank to use local billing records)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_CLEANUP_INTERVAL_SECONDS=300
WORKER_JOB_RETENTION_HOURS=24

# ML Service
ML_API_KEY=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8080
