{
  "name": "@testra/sdk",
  "version": "0.0.0",
  "description": "Official Testra TypeScript SDK",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "openapi-typescript ../../docs/api/openapi/openapi.yaml --output src/openapi.ts",
