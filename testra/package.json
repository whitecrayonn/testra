{
  "name": "@testra/monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Testra Intelligent Quality Engineering Platform monorepo",
  "scripts": {
    "dev": "node scripts/dev/start-infra.mjs && turbo run dev",
    "dev:all": "node scripts/dev/start-infra.mjs && turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "node scripts/dev/clean.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "postinstall": "node scripts/dev/setup-python.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.0.9"
  },
  "packageManager": "pnpm@9.5.0"
}
